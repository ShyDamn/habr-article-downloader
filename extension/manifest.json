{
  "manifest_version": 3,
  "name": "Habr Article Downloader",
  "version": "3.1.5",
  "description": "Скачивает публикации Habr в Markdown: вручную, пакетом, слежением и фильтрами",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage",
    "alarms",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": ["https://habr.com/*"],
  "action": {
    "default_title": "Habr → Markdown",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://habr.com/*"],
      "js": [
        "lib/turndown.js",
        "lib/turndown-plugin-gfm.js",
        "markdown.js",
        "parser.js",
        "content.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ]
}
